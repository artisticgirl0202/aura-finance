# ==========================================
# 🚀 Aura Finance - Production Environment Configuration
# ==========================================

# ==========================================
# 1. AI Intelligence (핵심 두뇌 - 필수!)
# ==========================================
# Google Gemini (1차 분류기)
# 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# OpenAI (2차 폴백)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Mock AI 모드 (둘 다 미설정 시 로컬 키워드 분류 사용) (OpenAI 크레딧 없이 테스트)
# true로 설정하면 OpenAI API를 사용하지 않고 로컬 키워드 기반 분류 사용
USE_MOCK_AI=false

# ==========================================
# 2. Open Banking (실제 금융 데이터 연동)
# ==========================================
# 실제 은행 계좌 연동을 위한 키 (Tink 또는 Plaid)
# 개발 단계에서는 Sandbox 키를 사용합니다.
BANKING_PROVIDER=tink  # 'tink' or 'plaid'

# Tink API (유럽/북유럽 권장)
# 발급: https://console.tink.com/
TINK_CLIENT_ID=your_tink_client_id_here
TINK_CLIENT_SECRET=your_tink_client_secret_here
TINK_ENVIRONMENT=sandbox  # 'sandbox' or 'production'

# Plaid API (북미/글로벌 권장)
# 발급: https://dashboard.plaid.com/
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENVIRONMENT=sandbox  # 'sandbox', 'development', or 'production'

# ==========================================
# 3. Database & Storage (영구 저장소)
# ==========================================
# 미설정 시 SQLite(로컬) 사용. 프로덕션은 PostgreSQL 필수.
# 로컬 SQLite: (생략 시 자동) sqlite+aiosqlite:///./aura_finance.db
# PostgreSQL: postgresql://user:pass@host:5432/db (Render는 postgres:// 형식도 지원)
# DATABASE_URL=postgresql://aura_user:secure_password@localhost:5432/aura_finance

# Redis 캐싱 (성능 최적화 - 선택사항)
# 로컬: redis://localhost:6379/0
# AWS ElastiCache 등 사용 가능
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600  # 캐시 유효 시간 (초)

# ==========================================
# 4. Security & Authentication (보안)
# ==========================================
# JWT 토큰 암호화에 사용되는 비밀키
# 생성 방법: openssl rand -hex 32
# ⚠️ 절대 외부 노출 금지!
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS 허용 도메인 (프로덕션 필수)
# 로컬: http://localhost:3000,http://localhost:5173
# Vercel: https://your-app.vercel.app (쉼표로 여러 개 가능)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# FRONTEND_URL (ALLOWED_ORIGINS 대신 단일 URL 사용 가능)
# FRONTEND_URL=https://your-app.vercel.app

# ==========================================
# 5. Server Configuration (기본 설정)
# ==========================================
# ENV=development: 로컬 개발 (SECRET_KEY 생략 시 기본값 사용)
# ENV=production: Render 등 (SECRET_KEY 필수)
ENV=development

# Render 등 클라우드는 PORT를 자동 할당
DEBUG=True  # 프로덕션에서는 False로 변경
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==========================================
# 6. External Services (외부 서비스 - 선택)
# ==========================================
# Sentry (에러 모니터링)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# AWS S3 (파일 저장소)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=aura-finance-assets

# SendGrid (이메일 발송)
# SENDGRID_API_KEY=your_sendgrid_api_key

# ==========================================
# 7. Feature Flags (기능 토글)
# ==========================================
ENABLE_CACHING=true
ENABLE_BATCH_PROCESSING=true
ENABLE_WEBSOCKET=false
MAX_TRANSACTIONS_PER_BATCH=100
